  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'CMD=\"$CLAUDE_TOOL_INPUT_COMMAND\"; DANGEROUS_RE=(\"rm[[:space:]]+-[[:alpha:]]*[rR]\" \"rm[[:space:]]+--recursive\" \"sudo\" \"chmod[[:space:]]+777\" \"git[[:space:]]+push[[:space:]]+.*(-f|--force)\" \"npm[[:space:]]+publish\" \"poetry[[:space:]]+publish\" \"uv[[:space:]]+publish\" \"eval[[:space:]]\" \"exec[[:space:]]\" \"\\$\\([[:space:]]*curl\" \"\\$\\([[:space:]]*wget\" \"(cat|head|tail|less|more)[[:space:]]+.*\\.env\" \"(cat|head|tail|less|more)[[:space:]]+.*secrets/\" \"(cat|head|tail|less|more)[[:space:]]+.*\\.pem\" \"(cat|head|tail|less|more)[[:space:]]+.*\\.key\" \"echo[[:space:]]+.*\\\\\\$\" \"(poetry|uv)[[:space:]]+run[[:space:]]+(bash|sh|python[[:space:]]+-c|python3[[:space:]]+-c|node[[:space:]]+-e)\" \"find[[:space:]]+.*-exec\" \"(g|m|n)?awk[[:space:]]\" \"sed[[:space:]].*s[/].*[/].*[/][[:alpha:]]*e\" \"perl[[:space:]]\"); for P in \"${DANGEROUS_RE[@]}\"; do if printf \"%s\" \"$CMD\" | tr \"\\n\" \" \" | grep -qE \"$P\"; then echo \"[SECURITY] 危険なコマンドがブロックされました: $P\" >&2; exit 2; fi; done; exit 0'"
          },
          {
            "type": "command",
            "command": "bash -c 'CMD=\"$CLAUDE_TOOL_INPUT_COMMAND\"; PS_RE=(\"[Ii]nvoke-[Ee]xpression\" \"[Ii]nvoke-[Ww]eb[Rr]equest\" \"[Ii]nvoke-[Rr]est[Mm]ethod\" \"[Ss]tart-[Pp]rocess\" \"powershell\" \"pwsh[[:space:]]+-[eEcC]\" \"[Ss]et-[Ee]xecution[Pp]olicy\" \"certutil.*-urlcache\" \"rundll32\" \"mshta\" \"regsvr32\" \"cscript\" \"wscript\" \"bitsadmin\" \"cmd[[:space:]]*/[cCkK]\" \"cmd\\.exe\" \"sc\\.exe\" \"reg\\.exe\" \"reg[[:space:]]+(add|delete)\" \"bcdedit\" \"wmic\" \"net[[:space:]]+(user|localgroup|share)\" \"runas\" \"msiexec\"); for P in \"${PS_RE[@]}\"; do if printf \"%s\" \"$CMD\" | tr \"\\n\" \" \" | grep -qiE \"$P\"; then echo \"[SECURITY] PowerShell/Windows の危険なコマンドがブロックされました: $P\" >&2; exit 2; fi; done; exit 0'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'mkdir -p ~/.local/share/claude && echo \"[AUDIT] ファイル変更: $CLAUDE_TOOL_INPUT_FILE_PATH ($(date -u +\"%Y-%m-%dT%H:%M:%SZ\"))\" >> ~/.local/share/claude/audit.log 2>/dev/null || true'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'mkdir -p ~/.local/share/claude && printf \"[AUDIT] Bash実行: %s (%s)\\n\" \"$CLAUDE_TOOL_INPUT_COMMAND\" \"$(date -u +\"%Y-%m-%dT%H:%M:%SZ\")\" >> ~/.local/share/claude/bash-audit.log 2>/dev/null || true'"
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'mkdir -p ~/.local/share/claude && echo \"[AUDIT] 設定変更: $CLAUDE_CONFIG_CHANGE_KEY = $CLAUDE_CONFIG_CHANGE_VALUE (Session: $CLAUDE_SESSION_ID, $(date -u +\"%Y-%m-%dT%H:%M:%SZ\"))\" >> ~/.local/share/claude/config-audit.log 2>/dev/null || true'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /workspace/.claude/statusline-command.sh"
  },
  "extraKnownMarketplaces": {
    "spec-coexist-local": {
      "source": {
